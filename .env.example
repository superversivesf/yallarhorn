# Yallarhorn Docker Environment Configuration
# Copy this file to .env and customize paths for your system

# Data directory - stores SQLite database
# Default: ./data (relative to docker-compose.yml location)
YALLARHORN_DATA_DIR=./data

# Downloads directory - stores downloaded videos/audio
# RECOMMENDED: Put this on your bulk storage drive
# Example: /mnt/bulk-storage/yallarhorn/downloads
YALLARHORN_DOWNLOADS_DIR=./downloads

# Temp directory - temporary files during processing
# Can be on fast local storage
YALLARHORN_TEMP_DIR=./temp

# Debug mode - enables SQL query logging and detailed logs
# Set to "true" for development/troubleshooting, "false" for production
# Default: false
YALLARHORN_DEBUG_MODE=false

# yt-dlp cookies file path - for YouTube authentication
# Optional: Set if you get "Sign in to confirm you're not a bot" errors
# Export cookies from your browser after logging into YouTube
# See docs/COOKIES_SETUP.md for instructions
# Example: /app/config/cookies.txt
# YALLARHORN_YTDLP_COOKIES_PATH=

# yt-dlp proxy URL - route YouTube requests through a proxy/VPN
# Optional: Helps avoid bot detection by appearing from different IPs
# Examples:
#   HTTP proxy: http://proxy.example.com:8080
#   SOCKS5 proxy: socks5://127.0.0.1:1080
# For Docker, use host.docker.internal to reach host proxy:
#   socks5://host.docker.internal:1080
# YALLARHORN_YTDLP_PROXY_URL=